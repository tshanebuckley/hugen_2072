
# initial setup of variables
scratch=$SLURM_SCRATCH
outdir=$SLURM_SUBMIT_DIR/p4
mkdir -p $outdir
p4=/ix1/hugen2072-2026s/p4

# extract chromosome 22 alignments
samtools view -T "$p4/GRCh38_full_analysis_set_plus_decoy_hla.fa" \
  -bS \
  -o "$scratch/NA12778.chr22.bam" \
  -h "$p4/NA12778.final.cram" chr22

# index the bam file 
samtools index $scratch/NA12778.chr22.bam

# pull the singularity image if we do not have it
manta=$outdir/manta.sif
if [[ -f "$manta" ]]; then
    echo "Manta image '$manta' found locally."
else
    echo "$FILE Manta image '$manta' not found, fetching from biocontainers."
    set +e
    singularity pull $manta docker://quay.io/biocontainers/manta:1.6.0--py27_0
    set -e
fi
Manta image '/ihome/adombrovski/tsb31/p4/manta.sif' found locally.

# set up the config for manta
# NOTE: the separate mounting of scratch and p4 directories
# also setting scratch dir as the output directory given these docs:
# https://pmbio.org/module-05-somatic/0005/03/01/Somatic_SV_Calling/
singularity exec -B "$scratch:/scratch" -B "$p4:/p4" $manta \
  configManta.py \
  --referenceFasta=/p4/GRCh38_full_analysis_set_plus_decoy_hla.fa \
  --bam=/scratch/NA12778.chr22.bam \
  --runDir=/scratch
WARNING: Skipping mount /software/rhel9/manual/install/singularity/4.3.2/var/singularity/mnt/session/etc/resolv.conf [files]: /etc/resolv.conf doesn't exist in container

Successfully created workflow run script.
To execute the workflow, run the following script and set appropriate options:

/scratch/runWorkflow.py

# ls here to ensure to log the state of the scratch directory
# want to log if the config files exist in the scratch dir
echo "---------------------------------------------------"
---------------------------------------------------
ls $scratch
NA12778.chr22.bam
NA12778.chr22.bam.bai
results
runWorkflow.py
runWorkflow.py.config.pickle
workspace
echo "---------------------------------------------------"
---------------------------------------------------

# now that manta is configured, actually run manta
# NOTE: binding the same dirs as in the config step
singularity exec -B "$scratch:/scratch" -B "$p4:/p4" $manta \
  python /scratch/runWorkflow.py
