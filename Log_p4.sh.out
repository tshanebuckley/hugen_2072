| awk '{if ($5 ~ "DEL" || $5 ~ "DUP") print}' \
  | awk -F"[\t;]" '{print $1, $2, $8, $5}' OFS="\t" \
  | sed 's/END=//g' \
  | awk '{if ($3 - $2 >= 1000) print}' > $outdir/gt1kb.cnv.bed

